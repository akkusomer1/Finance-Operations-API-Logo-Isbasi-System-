{
  "UseInMemoryDatabase": false,
  "ConnectionStrings": {
    "ApplicationConnection": "Data Source=localhost; Initial Catalog=ZeusAppDB; User Id=****; Password=****; MultipleActiveResultSets=True; TrustServerCertificate=True;",
    "IdentityConnection": "Data Source=localhost; Initial Catalog=ZeusAppDB; User Id=****; Password=****; MultipleActiveResultSets=True; TrustServerCertificate=True;"
  },
  "JWTSettings": {
    "Key": "CHANGE_ME_WITH_A_SECURE_ENVIRONMENT_SECRET_32_CHARS_MINIMUM",
    "Issuer": "ZeusApp.WebApi",
    "Audience": "ZeusApp.WebApi.User",
    "DurationInMinutes": 43200
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "MailSettings": {
    "From": "****",
    "Host": "smtp.example.com",
    "Port": 587,
    "UserName": "****",
    "Password": "****",
    "DisplayName": "ZeusApp"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp} [{Level}] {Message}{NewLine:1}"
        }
      },
      {
        "Name": "RollingFile",
        "Args": {
          "pathFormat": "Log\\log-{Date}.log",
          "outputTemplate": "{Timestamp} [{Level}] {Message}{NewLine:1}"
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Data Source=localhost; Initial Catalog=ZeusAppLogs; User ID=****; Password=****; MultipleActiveResultSets=True",
          "tableName": "Log",
          "columnOptionsSection": {
            "addStandardColumns": [ "LogEvent" ],
            "removeStandardColumns": [ "Properties" ]
          }
        }
      }

    ],
    "Properties": {
      "Application": "ZeusApp.WebApi"
    }
  }
}
